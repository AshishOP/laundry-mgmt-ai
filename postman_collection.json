        {
            "name": "Orders",
            "item": [
                {
                    "name": "Get All Orders",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/orders?status=PROCESSING",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "orders"
                            ],
                            "query": [
                                {
                                    "key": "status",
                                    "value": "PROCESSING"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Create Order",
                    "request": {
                        "method": "POST",
                        "header": [
